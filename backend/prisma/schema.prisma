generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------
// 1. ตารางผู้ใช้งานระบบ (พนักงาน / ผู้จัดการ)
// ------------------------------------------------------
model User {
  id        String   @id @default(uuid())
  email     String   @unique // 🟢 เพิ่ม Email เพราะหน้า Login พนักงานใช้อีเมล
  phone     String?  @unique // 🟢 เพิ่มเบอร์โทร (พนักงานอาจจะผูกเบอร์ไว้ดูในหน้า Profile)
  password  String   
  name      String
  role      String   @default("front-staff") // 🟢 Role: manager, front-staff, laundry-staff
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ------------------------------------------------------
// 2. ตารางลูกค้า (Customer)
// ------------------------------------------------------
model Customer {
  id        String   @id @default(uuid())
  phone     String   @unique // 🟢 ลูกค้าใช้เบอร์โทรในการ Login
  email     String?  @unique // 🟢 เพิ่ม Email (อิงจากฟอร์มลงทะเบียนลูกค้าใหม่)
  password  String?  // 🟢 เพิ่ม Password ให้ลูกค้าล็อกอิน (ตั้งเป็น Optional (?) เผื่อลูกค้าเข้าด้วย OTP อย่างเดียว)
  name      String
  address   String?
  points    Int      @default(0) // แต้มสะสม
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ------------------------------------------------------
// 3. ตารางออเดอร์ (Order)
// ------------------------------------------------------
model Order {
  id                  String      @id @default(uuid())
  orderNumber         String      @unique 
  customerId          String
  status              String      @default("pending") 
  totalAmount         Float
  notes               String?
  
  // 🟢 สิ่งที่เพิ่มเข้ามา: สถานะและช่องทางการชำระเงิน
  paymentStatus       String      @default("unpaid")
  paymentMethod       String?
  
  customer            Customer    @relation(fields: [customerId], references: [id])
  payment             Payment?
  
  items               OrderItem[] 
  estimatedCompletion DateTime?   

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ------------------------------------------------------
// 4. ตารางการชำระเงิน (Payment)
// ------------------------------------------------------
model Payment {
  id          String   @id @default(uuid())
  orderId     String   @unique
  amount      Float
  method      String   // cash, promptpay, credit
  status      String   @default("paid") // pending, paid
  
  order       Order    @relation(fields: [orderId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ------------------------------------------------------
// 5. ตารางรายการผ้า (Item ในแต่ละออเดอร์)
// ------------------------------------------------------
model OrderItem {
  id           String  @id @default(uuid())
  orderId      String
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  type         String  // ประเภทผ้า เช่น เสื้อเชิ้ต, กางเกงยีนส์
  service      String  // บริการ เช่น ซักพับ, ซักรีด
  quantity     Int     // จำนวน
  pricePerItem Float   // ราคาต่อชิ้น
}

// 🟡 [เพื่อนๆ] ถ้าจะเพิ่มตารางใหม่ (Table) เช่น Order, LaundryItem 
// ให้มานิยาม Model ต่อจากตรงนี้ครับ
// อย่าลืมรัน `bunx prisma db push` หลังแก้เสร็จนะ!